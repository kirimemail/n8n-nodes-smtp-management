{
	"name": "@kirimemail/n8n-nodes-smtp-management",
	"version": "0.3.1",
	"description": "Kirim.Email SMTP management node for n8n - validate emails, check quota, and send emails",
	"homepage": "https://kirim.email",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Gamal Abdul Nasser",
		"email": "gamalan@kirim.email"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kirimemail/n8n-nodes-smtp-management.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/KirimEmailSmtpUserApi.credentials.js",
			"dist/credentials/KirimEmailSmtpWebhookApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/KirimEmailValidation/KirimEmailValidation.node.js",
			"dist/nodes/KirimEmailQuota/KirimEmailQuota.node.js",
			"dist/nodes/KirimEmailMessage/KirimEmailMessage.node.js",
			"dist/nodes/KirimEmailSmtpWebhookTrigger/KirimEmailSmtpWebhookTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
